generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  user_id      Int        @id @default(autoincrement())
  first_name   String
  last_name    String
  username     String     @unique
  email        String     @unique
  profile_picture String?
  phone        String?
  city         String?
  pincode      String?
  password     String
  account_status String   @default("active")
  suspended_reason String?
  suspended_at DateTime?
  created_at   DateTime   @default(now())
  freelancer   Freelancer?
  client       Client?
  reviews      Review[]
  reports_filed Report[]  @relation("ReportsFiled")
  reports_against Report[] @relation("ReportsAgainst")
  reports_reviewed Report[] @relation("ReportsReviewed")
}

model Freelancer {
  freelancer_id  Int               @id @default(autoincrement())
  user_id        Int               @unique
  college_name   String?
  degree         String?
  year_of_study  Int?
  portfolio      String?
  resume         String?
  availability   Boolean           @default(true)
  status         String            @default("active")
  user           User              @relation(fields: [user_id], references: [user_id], onDelete: Cascade)
  skills         FreelancerSkill[]
  applications   Application[]
  contracts      Contract[]
}

model Client {
  client_id      Int         @id @default(autoincrement())
  user_id        Int         @unique
  client_type    String
  portfolio      String?
  resume         String?
  user           User        @relation(fields: [user_id], references: [user_id], onDelete: Cascade)
  projects       Project[]
  contracts      Contract[]
}

model Skill {
  skill_id       Int               @id @default(autoincrement())
  skill_name     String            @unique
  description    String?
  freelancers    FreelancerSkill[]
  projectSkills  ProjectSkill[]
}

model FreelancerSkill {
  id             Int         @id @default(autoincrement())
  freelancer_id  Int
  skill_id       Int
  freelancer     Freelancer  @relation(fields: [freelancer_id], references: [freelancer_id], onDelete: Cascade)
  skill          Skill       @relation(fields: [skill_id], references: [skill_id], onDelete: Cascade)

  @@unique([freelancer_id, skill_id])
}

model Project {
  project_id      Int           @id @default(autoincrement())
  client_id       Int
  title           String
  description     String
  budget          Decimal       @db.Decimal(12, 2)
  work_mode       String        @default("remote")
  engagement_type String        @default("full_time")
  address         String?
  area            String?
  tech_stack      String[]      @default([])
  deadline        DateTime
  posted_date     DateTime      @default(now())
  project_status  String        @default("open")
  client          Client        @relation(fields: [client_id], references: [client_id], onDelete: Cascade)
  requiredSkills  ProjectSkill[]
  applications    Application[]
  contracts       Contract[]
}

model ProjectSkill {
  id          Int      @id @default(autoincrement())
  project_id  Int
  skill_id    Int
  project     Project  @relation(fields: [project_id], references: [project_id], onDelete: Cascade)
  skill       Skill    @relation(fields: [skill_id], references: [skill_id], onDelete: Cascade)

  @@unique([project_id, skill_id])
}

model Application {
  application_id  Int         @id @default(autoincrement())
  project_id      Int
  freelancer_id   Int
  applied_date    DateTime    @default(now())
  project         Project     @relation(fields: [project_id], references: [project_id], onDelete: Cascade)
  freelancer      Freelancer  @relation(fields: [freelancer_id], references: [freelancer_id], onDelete: Cascade)

  @@unique([project_id, freelancer_id])
}

model Contract {
  contract_id     Int         @id @default(autoincrement())
  project_id      Int
  freelancer_id   Int
  client_id       Int
  agreed_amount   Decimal     @db.Decimal(12, 2)
  contract_scope  String      @default("full_project")
  task_description String?
  start_date      DateTime
  end_date        DateTime?
  status          String      @default("active")
  project         Project     @relation(fields: [project_id], references: [project_id], onDelete: Cascade)
  freelancer      Freelancer  @relation(fields: [freelancer_id], references: [freelancer_id], onDelete: Cascade)
  client          Client      @relation(fields: [client_id], references: [client_id], onDelete: Cascade)
  reviews         Review[]
  payments        Payment[]
  reports         Report[]
}

model Review {
  review_id       Int       @id @default(autoincrement())
  contract_id     Int
  user_id         Int
  rating          Int
  comment         String?
  contract        Contract  @relation(fields: [contract_id], references: [contract_id], onDelete: Cascade)
  user            User      @relation(fields: [user_id], references: [user_id], onDelete: Cascade)
}

model Payment {
  payment_id        Int       @id @default(autoincrement())
  contract_id       Int
  amount            Decimal   @db.Decimal(12, 2)
  payment_status    String    @default("pending")
  transaction_date  DateTime  @default(now())
  contract          Contract  @relation(fields: [contract_id], references: [contract_id], onDelete: Cascade)
}

model Report {
  report_id            Int       @id @default(autoincrement())
  contract_id          Int
  reporter_user_id     Int
  reported_user_id     Int
  reason               String
  description          String?
  status               String    @default("pending")
  review_notes         String?
  reviewed_by_user_id  Int?
  reviewed_at          DateTime?
  created_at           DateTime  @default(now())
  updated_at           DateTime  @updatedAt
  contract             Contract  @relation(fields: [contract_id], references: [contract_id], onDelete: Cascade)
  reporter             User      @relation("ReportsFiled", fields: [reporter_user_id], references: [user_id], onDelete: Cascade)
  reported_user        User      @relation("ReportsAgainst", fields: [reported_user_id], references: [user_id], onDelete: Cascade)
  reviewed_by          User?     @relation("ReportsReviewed", fields: [reviewed_by_user_id], references: [user_id], onDelete: SetNull)

  @@unique([contract_id, reporter_user_id])
  @@index([reported_user_id, status])
  @@index([status, created_at])
}
