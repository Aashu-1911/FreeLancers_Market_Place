generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  user_id      Int        @id @default(autoincrement())
  first_name   String
  last_name    String
  email        String     @unique
  phone        String?
  city         String?
  pincode      String?
  password     String
  created_at   DateTime   @default(now())
  freelancer   Freelancer?
  client       Client?
  reviews      Review[]
}

model Freelancer {
  freelancer_id  Int               @id @default(autoincrement())
  user_id        Int               @unique
  college_name   String?
  degree         String?
  year_of_study  Int?
  portfolio      String?
  resume         String?
  availability   Boolean           @default(true)
  status         String            @default("active")
  user           User              @relation(fields: [user_id], references: [user_id], onDelete: Cascade)
  skills         FreelancerSkill[]
  applications   Application[]
  contracts      Contract[]
}

model Client {
  client_id      Int         @id @default(autoincrement())
  user_id        Int         @unique
  client_type    String
  user           User        @relation(fields: [user_id], references: [user_id], onDelete: Cascade)
  projects       Project[]
  contracts      Contract[]
}

model Skill {
  skill_id       Int               @id @default(autoincrement())
  skill_name     String            @unique
  description    String?
  freelancers    FreelancerSkill[]
}

model FreelancerSkill {
  id             Int         @id @default(autoincrement())
  freelancer_id  Int
  skill_id       Int
  freelancer     Freelancer  @relation(fields: [freelancer_id], references: [freelancer_id], onDelete: Cascade)
  skill          Skill       @relation(fields: [skill_id], references: [skill_id], onDelete: Cascade)

  @@unique([freelancer_id, skill_id])
}

model Project {
  project_id      Int           @id @default(autoincrement())
  client_id       Int
  title           String
  description     String
  budget          Decimal       @db.Decimal(12, 2)
  deadline        DateTime
  posted_date     DateTime      @default(now())
  project_status  String        @default("open")
  client          Client        @relation(fields: [client_id], references: [client_id], onDelete: Cascade)
  applications    Application[]
  contracts       Contract[]
}

model Application {
  application_id  Int         @id @default(autoincrement())
  project_id      Int
  freelancer_id   Int
  applied_date    DateTime    @default(now())
  project         Project     @relation(fields: [project_id], references: [project_id], onDelete: Cascade)
  freelancer      Freelancer  @relation(fields: [freelancer_id], references: [freelancer_id], onDelete: Cascade)

  @@unique([project_id, freelancer_id])
}

model Contract {
  contract_id     Int         @id @default(autoincrement())
  project_id      Int
  freelancer_id   Int
  client_id       Int
  agreed_amount   Decimal     @db.Decimal(12, 2)
  start_date      DateTime
  end_date        DateTime?
  status          String      @default("active")
  project         Project     @relation(fields: [project_id], references: [project_id], onDelete: Cascade)
  freelancer      Freelancer  @relation(fields: [freelancer_id], references: [freelancer_id], onDelete: Cascade)
  client          Client      @relation(fields: [client_id], references: [client_id], onDelete: Cascade)
  reviews         Review[]
  payments        Payment[]
}

model Review {
  review_id       Int       @id @default(autoincrement())
  contract_id     Int
  user_id         Int
  rating          Int
  comment         String?
  contract        Contract  @relation(fields: [contract_id], references: [contract_id], onDelete: Cascade)
  user            User      @relation(fields: [user_id], references: [user_id], onDelete: Cascade)
}

model Payment {
  payment_id        Int       @id @default(autoincrement())
  contract_id       Int
  amount            Decimal   @db.Decimal(12, 2)
  payment_status    String    @default("pending")
  transaction_date  DateTime  @default(now())
  contract          Contract  @relation(fields: [contract_id], references: [contract_id], onDelete: Cascade)
}
